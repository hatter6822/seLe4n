            rw [storeObject_objects_ne st st1 notificationId waiter.toObjId _ hNe hObjInv hSO]; exact hWTcb
          have hWaiterNotBlocked : (∀ ep, wTcb.ipcState ≠ .blockedOnReceive ep) ∧
