    (st st' : SystemState) (notificationId : SeLe4n.ObjId) (badge : SeLe4n.Badge)
    (hObjInv : st.objects.invExt) (hInv : endpointQueueTailBlockedConsistent st)
    (hNWC : notificationWaiterConsistent st)
