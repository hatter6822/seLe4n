  · rw [hEq, storeObject_objects_eq st st' id obj hObjInv hStore] at hTcb'
    exact absurd (Option.some.inj hTcb') (hNewNonTcb tcb')
  · rw [storeObject_objects_ne st st' id tid.toObjId obj hEq hObjInv hStore] at hTcb'
    exact ⟨tcb', hTcb', rfl⟩

