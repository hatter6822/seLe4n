              e.sendQ.head ≠ some receiver ∧ e.sendQ.tail ≠ some receiver ∧
              e.receiveQ.head ≠ some receiver ∧ e.receiveQ.tail ≠ some receiver :=
            fun epId e hEp =>
              hFreshReceiver epId e (cleanupPreReceiveDonation_endpoint_backward st receiver hObjInv
                epId e hEp)
