                · rename_i pair
                  simp only []
                  have hInv1 := storeObject_preserves_objects_invExt' st endpointId _ pair hObjInv hStore
                  have hP1 := storeObject_endpoint_preserves_blockedOnReplyHasTarget'
                    st endpointId _ pair hObjInv hInv hStore
