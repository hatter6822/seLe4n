              obtain ⟨_, rfl⟩ := hStep
              exact endpointReceiveDual_preserves_donationBudgetTransfer
                (ensureRunnable stReplied replyTarget) pair.2 endpointId receiver pair.1 replyId hDE hObjInvE hRecv
        · simp at hStep

